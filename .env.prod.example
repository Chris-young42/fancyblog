# Production Environment Variables
# Copy this file to .env.prod and modify as needed

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_DATABASE=blog_db
MYSQL_USER=blog_user
MYSQL_PASSWORD=your_secure_blog_password
MYSQL_PORT=3306

# Frontend service ports (independent Nginx)
FRONTEND_FANCY_PORT=8080
FRONTEND_ADMIN_PORT=8081

# JWT Secrets (change these in production)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# SMTP Configuration (optional, for password reset emails)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
